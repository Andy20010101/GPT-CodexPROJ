{
  "name": "@review-then-codex/chatgpt-web-bridge",
  "version": "0.1.0",
  "private": true,
  "description": "Service layer that bridges ChatGPT Web sessions into a typed HTTP API.",
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx src/index.ts",
    "check:browser-attach": "TMPDIR=/tmp tsx ../../scripts/check-browser-attach.ts",
    "test": "TMPDIR=/tmp vitest run",
    "test:real": "tsx tests/real/bridge-smoke.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@review-then-codex/shared-contracts": "file:../../packages/shared-contracts",
    "fastify": "^4.28.1",
    "pino": "^9.3.2",
    "puppeteer-core": "^24.9.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "tsx": "^4.16.5",
    "vitest": "^2.0.5"
  }
}
