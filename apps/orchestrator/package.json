{
  "name": "@gpt-codexproj/orchestrator",
  "version": "0.1.0",
  "private": true,
  "description": "Control-plane skeleton for requirement freeze, architecture freeze, task loops, evidence, and gates.",
  "scripts": {
    "dev": "tsx src/api/server.ts",
    "dev:api": "tsx src/api/server.ts",
    "daemon": "TMPDIR=/tmp tsx ../../scripts/run-orchestrator-daemon.ts",
    "test": "TMPDIR=/tmp vitest run tests/unit tests/integration",
    "test:integration": "TMPDIR=/tmp vitest run tests/integration",
    "test:unit": "TMPDIR=/tmp vitest run tests/unit",
    "test:all": "TMPDIR=/tmp vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@gpt-codexproj/shared-contracts": "file:../../packages/shared-contracts",
    "fastify": "^5.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "tsx": "^4.16.5",
    "vitest": "^2.0.5"
  }
}
