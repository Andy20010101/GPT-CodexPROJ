# Copy to `.env.local` for local development. Only set the values you actually use.

# Bridge service
HOST=127.0.0.1
PORT=3100
BRIDGE_ARTIFACT_DIR=services/chatgpt-web-bridge/artifacts
BRIDGE_BROWSER_URL=https://chatgpt.com/
BRIDGE_BROWSER_URL_CANDIDATES=http://127.0.0.1:9222
BRIDGE_BROWSER_PORTS=9222
BRIDGE_BROWSER_CONNECT_URL=http://127.0.0.1:9222
BRIDGE_PROJECT_NAME=Default

# Orchestrator service
ORCHESTRATOR_API_HOST=127.0.0.1
ORCHESTRATOR_API_PORT=3200
ORCHESTRATOR_ARTIFACT_DIR=apps/orchestrator/artifacts
BRIDGE_BASE_URL=http://127.0.0.1:3100
WORKSPACE_RUNTIME_BASE_DIR=apps/orchestrator/artifacts/workspace-runtime
WORKSPACE_SOURCE_REPO_PATH=.

# Execution
CODEX_RUNNER_MODE=stub
CODEX_CLI_BIN=codex
CODEX_CLI_TIMEOUT_MS=600000
REVIEW_MODEL_HINT=gpt-5.4

# Runtime behavior
RUNTIME_MAX_ATTEMPTS=2
RUNTIME_BACKOFF_STRATEGY=fixed
RUNTIME_BASE_DELAY_MS=0
DAEMON_POLL_INTERVAL_MS=250
DAEMON_WORKER_COUNT=2
DAEMON_HEARTBEAT_INTERVAL_MS=500
DAEMON_LEASE_TTL_MS=2000
DAEMON_STALE_THRESHOLD_MS=3000
DAEMON_MAX_CONCURRENT_JOBS=2
DAEMON_MAX_CONCURRENT_JOBS_PER_RUN=1
DAEMON_GC_INTERVAL_MS=1000

# Workspace retention
WORKSPACE_TTL_MS=3600000
WORKSPACE_RETAIN_ON_FAILURE=true
WORKSPACE_RETAIN_ON_REJECTED_REVIEW=true
WORKSPACE_RETAIN_ON_DEBUG=true
WORKSPACE_MAX_RETAINED_PER_RUN=3
WORKSPACE_CLEANUP_MODE=delayed
