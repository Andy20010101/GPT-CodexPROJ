{
  "name": "gpt-codexproj",
  "version": "0.1.0",
  "private": true,
  "description": "GPT-CodexPROJ: architecture-first monorepo for review, planning, and execution collaboration.",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "ci": "npm run typecheck && npm run test",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint:orchestrator && npm run lint:bridge && npm run lint:contracts && npm run lint:scripts",
    "lint:orchestrator": "npm run lint:orchestrator:src && npm run lint:orchestrator:tests",
    "lint:orchestrator:src": "NODE_OPTIONS=--max-old-space-size=4096 eslint apps/orchestrator/src --ext .ts",
    "lint:orchestrator:tests": "NODE_OPTIONS=--max-old-space-size=4096 eslint apps/orchestrator/tests --ext .ts",
    "lint:bridge": "NODE_OPTIONS=--max-old-space-size=4096 eslint services/chatgpt-web-bridge/src services/chatgpt-web-bridge/tests --ext .ts",
    "lint:contracts": "NODE_OPTIONS=--max-old-space-size=4096 eslint packages/shared-contracts/chatgpt --ext .ts",
    "lint:scripts": "NODE_OPTIONS=--max-old-space-size=4096 eslint scripts --ext .ts",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "typecheck:scripts": "tsc --noEmit -p tsconfig.scripts.json"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4"
  }
}
